<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="500" Width="350" ResizeMode="NoResize">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Поле для отображения выражения (предыдущие операции) -->
        <TextBox Grid.Row="0" Name="ExpressionBox" IsReadOnly="True"
                 TextAlignment="Right" FontSize="18" Margin="0,0,0,5"
                 Background="LightGray" Height="35" />

        <!-- Поле для текущего числа -->
        <TextBox Grid.Row="1" Name="CurrentBox" IsReadOnly="True"
                 TextAlignment="Right" FontSize="28" Margin="0,0,0,10"
                 Background="White" Height="45" Text="0" />

        <!-- Сетка для кнопок -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Первая строка: CE, C, <, / -->
            <Button Grid.Row="0" Grid.Column="0" Content="CE" Click="ButtonCE_Click" />
            <Button Grid.Row="0" Grid.Column="1" Content="C" Click="ButtonC_Click" />
            <Button Grid.Row="0" Grid.Column="2" Content="&lt;" Click="ButtonBackspace_Click" />
            <Button Grid.Row="0" Grid.Column="3" Content="/" Click="ButtonOperation_Click" />

            <!-- Вторая строка: 7,8,9,* -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Click="ButtonDigit_Click" />
            <Button Grid.Row="1" Grid.Column="1" Content="8" Click="ButtonDigit_Click" />
            <Button Grid.Row="1" Grid.Column="2" Content="9" Click="ButtonDigit_Click" />
            <Button Grid.Row="1" Grid.Column="3" Content="*" Click="ButtonOperation_Click" />

            <!-- Третья строка: 4,5,6,- -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Click="ButtonDigit_Click" />
            <Button Grid.Row="2" Grid.Column="1" Content="5" Click="ButtonDigit_Click" />
            <Button Grid.Row="2" Grid.Column="2" Content="6" Click="ButtonDigit_Click" />
            <Button Grid.Row="2" Grid.Column="3" Content="-" Click="ButtonOperation_Click" />

            <!-- Четвёртая строка: 1,2,3,+ -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Click="ButtonDigit_Click" />
            <Button Grid.Row="3" Grid.Column="1" Content="2" Click="ButtonDigit_Click" />
            <Button Grid.Row="3" Grid.Column="2" Content="3" Click="ButtonDigit_Click" />
            <Button Grid.Row="3" Grid.Column="3" Content="+" Click="ButtonOperation_Click" />

            <!-- Пятая строка: 0 (занимает 2 колонки), ., = -->
            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Click="ButtonDigit_Click" />
            <Button Grid.Row="4" Grid.Column="2" Content="." Click="ButtonDot_Click" />
            <Button Grid.Row="4" Grid.Column="3" Content="=" Click="ButtonEqual_Click" />
        </Grid>
    </Grid>
</Window>