<Window x:Class="WpfWASD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тренажёр WASD" Height="450" Width="500"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="StartButton" Content="Старт" Click="StartButton_Click" Width="80" Margin="0,0,10,0"/>
            <Button x:Name="StopButton" Content="Стоп" Click="StopButton_Click" Width="80" Margin="0,0,10,0" IsEnabled="False"/>
            <Label Content="Длина:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <Slider x:Name="LengthSlider" Minimum="5" Maximum="30" Value="10" Width="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
            <Label x:Name="LengthLabel" Content="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- Генерируемая строка -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">
            <Label Content="Введите: " FontSize="20" VerticalAlignment="Center"/>
            <TextBlock x:Name="TargetTextBlock" FontSize="30" FontWeight="Bold" VerticalAlignment="Center" Text=""/>
        </StackPanel>

        <!-- Статистика -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
            <Label Content="Правильно: " FontSize="16"/>
            <Label x:Name="CorrectLabel" Content="0" FontSize="16" Foreground="Green"/>
            <Label Content="  Ошибки: " FontSize="16" Margin="20,0,0,0"/>
            <Label x:Name="ErrorsLabel" Content="0" FontSize="16" Foreground="Red"/>
            <Label Content="  Скорость: " FontSize="16" Margin="20,0,0,0"/>
            <Label x:Name="SpeedLabel" Content="0 зн/мин" FontSize="16"/>
        </StackPanel>

        <!-- Клавиши WASD -->
        <Grid Grid.Row="3" Margin="0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" 
                    x:Name="KeyW" Background="LightGray" BorderBrush="Gray" BorderThickness="2" CornerRadius="8"
                    Margin="5">
                <TextBlock Text="W" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" 
                    x:Name="KeyA" Background="LightGray" BorderBrush="Gray" BorderThickness="2" CornerRadius="8"
                    Margin="5">
                <TextBlock Text="A" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" 
                    x:Name="KeyS" Background="LightGray" BorderBrush="Gray" BorderThickness="2" CornerRadius="8"
                    Margin="5">
                <TextBlock Text="S" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="3" Grid.RowSpan="2" 
                    x:Name="KeyD" Background="LightGray" BorderBrush="Gray" BorderThickness="2" CornerRadius="8"
                    Margin="5">
                <TextBlock Text="D" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Grid>
</Window>