<Window x:Class="PuzzleGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пазл" Height="600" Width="600" 
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Панель инструментов -->
        <ToolBar DockPanel.Dock="Top" Height="35" Background="LightGray">
            <Button Content="Новая игра" Click="NewGame_Click"/>
            <Button Content="Перемешать" Click="Shuffle_Click"/>
            <Separator/>
            <TextBlock Text="Ходов: " VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock x:Name="MovesLabel" Text="0" VerticalAlignment="Center" FontWeight="Bold"/>
        </ToolBar>
        <!-- Игровое поле -->
        <Border Margin="10" BorderBrush="Black" BorderThickness="2">
            <Grid x:Name="gameGrid">
                <!-- Здесь будут создаваться ячейки 4x4 -->
            </Grid>
        </Border>
    </DockPanel>
</Window>